generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id                 String                   @id @default(cuid())
  name               String
  email              String                   @unique
  role               Role                     @default(ATHLETE)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  passwordHash       String
  club               String?
  age                Int?
  birthDate          DateTime?
  backhand           String?
  dominance          String?
  gender             String?
  ranking            Int?
  rankings           Json?
  createdByUserId    String?
  matchesAsPlayer1   Match[]                  @relation("Player1")
  matchesAsPlayer2   Match[]                  @relation("Player2")
  endorsements       AnnotationEndorsement[]  @relation("Endorsements")
  annotationSessions MatchAnnotationSession[] @relation("AnnotationSessions")
}

model Match {
  id                 String                   @id @default(cuid())
  format             MatchFormat
  state              MatchState               @default(SCHEDULED)
  player1Id          String
  player2Id          String
  scoreState         Json?
  initialServerId    String?
  scheduledAt        DateTime?
  startedAt          DateTime?
  finishedAt         DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  sportType          String                   @default("TENNIS")
  courtType          String?
  nickname           String?
  visibility         String                   @default("PUBLIC")
  isResuming         Boolean                  @default(false)
  openForAnnotation  Boolean                  @default(false)
  tournamentName     String?
  round              String?
  bracketType        String?
  temperature        Float?
  humidity           Float?
  version            Int                      @default(0)
  category           String?
  includeLet         Boolean?
  winnerId           String?
  deletedAt          DateTime?
  deletedBy          String?
  finishNote         String?
  finishReason       MatchFinishReason?
  createdByUserId    String?
  player1            Player                   @relation("Player1", fields: [player1Id], references: [id])
  player2            Player                   @relation("Player2", fields: [player2Id], references: [id])
  pointLog           PointLog[]
  annotationSessions MatchAnnotationSession[]

  @@index([state])
  @@index([deletedAt])
}

model PointLog {
  id          String    @id @default(cuid())
  matchId     String
  winnerId    String
  type        PointType
  serverId    String
  annotations Json?
  timestamp   DateTime  @default(now())
  match       Match     @relation(fields: [matchId], references: [id])

  @@index([matchId])
}

model MatchAnnotationSession {
  id                 String                  @id @default(cuid())
  matchId            String
  annotatorUserId    String
  startedAt          DateTime                @default(now())
  endedAt            DateTime?
  matchStateSnapshot String?
  finalStateSnapshot String?
  isActive           Boolean                 @default(true)
  status             AnnotationSessionStatus @default(IN_PROGRESS)
  createdAt          DateTime                @default(now())
  endorsements       AnnotationEndorsement[]
  annotator          Player                  @relation("AnnotationSessions", fields: [annotatorUserId], references: [id], onDelete: Cascade)
  match              Match                   @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([annotatorUserId])
  @@index([isActive])
  @@map("match_annotation_sessions")
}

model AnnotationEndorsement {
  id               String                 @id @default(cuid())
  sessionId        String
  endorsedByUserId String
  endorsedAt       DateTime               @default(now())
  endorsedBy       Player                 @relation("Endorsements", fields: [endorsedByUserId], references: [id], onDelete: Cascade)
  session          MatchAnnotationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, endorsedByUserId])
  @@map("annotation_endorsements")
}

enum Role {
  ADMIN
  GESTOR
  COACH
  ATHLETE
  SPECTATOR
}

enum MatchState {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum MatchFinishReason {
  COMPLETED
  ABANDONED
  WALKOVER
  INJURY
  OUTRO
}

enum MatchFormat {
  BEST_OF_3
  BEST_OF_3_MATCH_TB
  BEST_OF_5
  SHORT_SET_2V2_NO_AD
  MATCH_TB_10
  PRO_SET_8
}

enum PointType {
  ACE
  WINNER
  FORCED_ERROR
  UNFORCED_ERROR
  DOUBLE_FAULT
  FAULT_SECOND
}

enum AnnotationSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}