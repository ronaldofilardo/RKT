generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Match {
  id                             String                      @id
  sportType                      String                      @default("TENNIS")
  courtType                      String?
  format                         MatchFormat
  state                          MatchState                  @default(SCHEDULED)
  player1Id                      String
  player2Id                      String
  scoreState                     Json?
  initialServerId                String?
  nickname                       String?
  version                        Int                         @default(0)
  visibility                     String                      @default("PUBLIC")
  isResuming                     Boolean                     @default(false)
  openForAnnotation              Boolean                     @default(false)
  tournamentName                 String?
  round                          String?
  bracketType                    String?
  temperature                    Float?
  humidity                       Float?
  scheduledAt                    DateTime?
  startedAt                      DateTime?
  finishedAt                     DateTime?
  createdAt                      DateTime                    @default(now())
  updatedAt                      DateTime
  category                       String?
  includeLet                     Boolean?
  createdByUserId                String?
  deletedAt                      DateTime?
  deletedBy                      String?
  finishNote                     String?
  winnerId                       String?
  finishReason                   String?
  Player_Match_player1IdToPlayer Player                      @relation("Match_player1IdToPlayer", fields: [player1Id], references: [id])
  Player_Match_player2IdToPlayer Player                      @relation("Match_player2IdToPlayer", fields: [player2Id], references: [id])
  PointLog                       PointLog[]
  match_annotation_sessions      match_annotation_sessions[]

  @@index([deletedAt])
  @@index([state])
}

model Player {
  id                            String                      @id
  name                          String
  email                         String                      @unique
  role                          Role                        @default(ATHLETE)
  club                          String?
  createdAt                     DateTime                    @default(now())
  updatedAt                     DateTime
  gender                        String?
  age                           Int?
  dominance                     String?
  backhand                      String?
  ranking                       Int?
  passwordHash                  String
  createdByUserId               String?
  rankings                      Json?
  Match_Match_player1IdToPlayer Match[]                     @relation("Match_player1IdToPlayer")
  Match_Match_player2IdToPlayer Match[]                     @relation("Match_player2IdToPlayer")
  annotation_endorsements       annotation_endorsements[]
  match_annotation_sessions     match_annotation_sessions[]
}

model PointLog {
  id          String    @id
  matchId     String
  winnerId    String
  type        PointType
  serverId    String
  annotations Json?
  timestamp   DateTime  @default(now())
  Match       Match     @relation(fields: [matchId], references: [id])

  @@index([matchId])
}

model annotation_endorsements {
  id                        String                    @id
  sessionId                 String
  endorsedByUserId          String
  endorsedAt                DateTime                  @default(now())
  Player                    Player                    @relation(fields: [endorsedByUserId], references: [id], onDelete: Cascade)
  match_annotation_sessions match_annotation_sessions @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, endorsedByUserId])
}

model match_annotation_sessions {
  id                      String                    @id
  matchId                 String
  annotatorUserId         String
  startedAt               DateTime                  @default(now())
  endedAt                 DateTime?
  matchStateSnapshot      String?
  finalStateSnapshot      String?
  isActive                Boolean                   @default(true)
  status                  AnnotationSessionStatus   @default(IN_PROGRESS)
  createdAt               DateTime                  @default(now())
  annotation_endorsements annotation_endorsements[]
  Player                  Player                    @relation(fields: [annotatorUserId], references: [id], onDelete: Cascade)
  Match                   Match                     @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([annotatorUserId])
  @@index([isActive])
  @@index([matchId])
}

enum AnnotationSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum MatchFormat {
  BEST_OF_3
  BEST_OF_3_MATCH_TB
  BEST_OF_3_NO_AD
  BEST_OF_5
  SHORT_SET_2V2_NO_AD
  MATCH_TB_10
  PRO_SET_8
}

enum MatchState {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  CANCELLED
}

enum PointType {
  ACE
  WINNER
  FORCED_ERROR
  UNFORCED_ERROR
  DOUBLE_FAULT
  FAULT_SECOND
}

enum Role {
  ADMIN
  GESTOR
  COACH
  ATHLETE
  SPECTATOR
}
